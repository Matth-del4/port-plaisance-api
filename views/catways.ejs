<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestion des Catways</title>
    <link rel="stylesheet" href="/dashboard.css" />
    <link rel="stylesheet" href="/crud.css" />
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-brand">Port Russell</div>
      <ul class="nav-menu">
        <li><a href="/dashboard">Accueil</a></li>
        <li><a href="/catways-page">Catways</a></li>
        <li><a href="/reservations-page">Réservations</a></li>
        <li><a href="/users-page">Utilisateurs</a></li>
        <li><a href="/api-docs" target="_blank">Documentation</a></li>
        <li><a href="#" id="logoutBtn">Déconnexion</a></li>
      </ul>
    </nav>

    <div class="container">
      <header class="page-header">
        <h2>Gestion des Catways</h2>
        <button id="addBtn" class="btn-primary">Nouveau Catway</button>
      </header>

      <div id="catwaysList"></div>

      <div id="modal" class="modal">
        <div class="modal-content">
          <span class="close">&times;</span>
          <h3 id="modalTitle">Nouveau Catway</h3>
          <form id="catwayForm">
            <div class="form-group">
              <label for="catwayNumber">Numéro *</label>
              <input type="number" id="catwayNumber" required />
            </div>
            <div class="form-group">
              <label for="catwayType">Type *</label>
              <select id="catwayType" required>
                <option value="short">Short</option>
                <option value="long">Long</option>
              </select>
            </div>
            <div class="form-group">
              <label for="catwayState">État *</label>
              <input type="text" id="catwayState" required />
            </div>
            <button type="submit" class="btn-primary">Enregistrer</button>
          </form>
        </div>
      </div>
    </div>

    <script src="/catways.js"></script>
  </body>
</html>
